# --- Next.js ---
# Local dev : PartyKit tourne en local sur 1999.
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999

# Prod : remplacer par ton domaine PartyKit deploy.
# NEXT_PUBLIC_PARTYKIT_HOST=pokrr.<ton-compte>.partykit.dev

# --- PartyKit (lu via .env au démarrage de `partykit dev`, exposé via room.env) ---
# Fenêtre de grâce avant élection auto d'un nouvel admin si l'admin se déconnecte.
# Défaut prod : 15 * 60 * 1000 = 900000 ms.
# En dev, valeur courte (2000 ms) pour tester rapidement.
POKRR_ADMIN_GRACE_MS=900000
