# --- Next.js front ---

# Hostname PartyKit (sans protocole).
# Local : localhost:1999. Prod : pokrr.<ton-compte>.partykit.dev.
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999

# URL canonique du site (optionnel, sinon Vercel utilise VERCEL_URL).
# Sert au metadataBase pour les balises Open Graph / Twitter.
# NEXT_PUBLIC_SITE_URL=https://pokrr.app

# --- PartyKit (chargé via .env au démarrage de `partykit dev`, exposé via room.env) ---

# Fenêtre de grâce avant élection auto d'un nouvel admin si l'admin se déconnecte.
# Défaut prod : 900000 ms (15 min). Mettre 2000 en dev pour tester rapidement.
POKRR_ADMIN_GRACE_MS=900000
